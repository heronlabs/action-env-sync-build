{
  "name": "action-env-sync-build",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub Action to fan a source branch out into target environment branches — merge if clean, open a PR if it conflicts",
  "license": "MIT",
  "author": "Heron Labs",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.js -o dist",
    "lint:check": "eslint .",
    "test:unit": "vitest run tests/unit"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.39.0",
    "globals": "^16.4.0",
    "vitest": "^4.0.6"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  }
}
